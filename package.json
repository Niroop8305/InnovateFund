{
  "name": "innovatefund",
  "version": "1.0.0",
  "description": "InnovateFund - Investment platform connecting entrepreneurs with investors",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "start": "npm start --prefix backend"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "investment",
    "innovation",
    "startup",
    "funding"
  ],
  "author": "InnovateFund Team",
  "license": "MIT"
}
