{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/socket.io/(.*)",
      "dest": "https://innovatefund-production.up.railway.app/socket.io/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://innovatefund-production.up.railway.app/api/$1"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
